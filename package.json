{
    "name": "rubiks-cube",
    "version": "1.0.0",
    "description": "Rubik's Cube interactive, browser-based simulator and visualizer built with TypeScript",
    "homepage": "https://mm6502.github.io/rubiks-cube",
    "repository": {
        "type": "git",
        "url": "https://github.com/mm6502/rubiks-cube.git"
    },
    "type": "module",
    "scripts": {
        "all": "cls && npm run lint:imports && cls && npm run format && cls && npm run type-check && cls && npm run test:coverage && npm run build",
        "all2": "npm run lint:imports && npm run format && npm run type-check && npm run test:coverage && npm run build",
        "demo": "npx tsx scripts/demo-video/record-demo.ts",
        "demo:video": "npx tsx scripts/demo-video/record-demo.ts --mode video",
        "demo:snapshots": "npx tsx scripts/demo-video/record-demo.ts --mode snapshots",
        "demo:assemble": "npx tsx scripts/demo-video/record-demo.ts --mode assemble",
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "type-check": "tsc --noEmit -p tsconfig.test.json",
        "test": "vitest --run --config vitest.config.ts",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "test:coverage:ui": "vitest --ui --coverage",
        "test:watch": "vitest",
        "lint:imports": "npx eslint --fix",
        "format": "prettier --write . --no-error-on-unmatched-pattern",
        "format:check": "prettier --check . --no-error-on-unmatched-pattern",
        "prepare": "husky",
        "precommit": "lint-staged && npm run type-check",
        "prepush": "npm test && npm run build"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{css,scss,md,json,yml,yaml}": [
            "prettier --write"
        ]
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@resvg/resvg-js": "^2.6.2",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/node": "^25.6.0",
        "@typescript-eslint/eslint-plugin": "^8.59.1",
        "@typescript-eslint/parser": "^8.59.1",
        "@vitest/coverage-v8": "^4.1.5",
        "@vitest/ui": "^4.1.5",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "fallow": "^2.89.0",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "prettier-plugin-organize-imports": "^4.3.0",
        "sass": "^1.99.0",
        "sharp": "^0.34.5",
        "typescript": "^6.0.3",
        "vite": "^8.0.10",
        "vite-plugin-singlefile": "^2.3.3",
        "vitest": "^4.1.5"
    },
    "dependencies": {
        "immutable": "^5.1.5"
    },
    "overrides": {}
}
